<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" styleClass="screen"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.sportconnect_01.controller.ClasesController">
    <children>
        <VBox layoutX="150.0" layoutY="30.0" prefHeight="540.0" prefWidth="600.0" spacing="14.0" styleClass="card">
            <children>
                <Label text="Clases disponibles" styleClass="title" />
                <Label text="Datos preparados para la tabla clases: título, descripción, deporte, profesor_id, premium y precio." wrapText="true" maxWidth="540.0" styleClass="normal-text" />

                <ScrollPane fitToWidth="true" prefHeight="370.0" prefWidth="540.0" styleClass="transparent-scroll">
                    <content>
                        <VBox fx:id="listaClasesBox" spacing="12.0" />
                    </content>
                </ScrollPane>

                <Button maxWidth="230.0" onAction="#onMisClasesClick" styleClass="primary-button" text="Ver mis clases" />
                <Button maxWidth="230.0" onAction="#onVolverClick" styleClass="secondary-button" text="Volver al inicio" />
            </children>
        </VBox>
    </children>
</AnchorPane>

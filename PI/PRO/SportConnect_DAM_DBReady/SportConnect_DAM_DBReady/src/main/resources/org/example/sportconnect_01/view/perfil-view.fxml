<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" styleClass="screen"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.sportconnect_01.controller.PerfilController">
    <children>
        <VBox alignment="CENTER" layoutX="235.0" layoutY="75.0" prefHeight="450.0" prefWidth="430.0" spacing="14.0" styleClass="card">
            <children>
                <Label text="Mi perfil" styleClass="title" />
                <Label fx:id="idLabel" text="ID usuario:" styleClass="normal-text" />
                <Label fx:id="nombreLabel" text="Nombre:" styleClass="subtitle" />
                <Label fx:id="apellidoLabel" text="Apellido:" styleClass="normal-text" />
                <Label fx:id="nickLabel" text="Nick:" styleClass="normal-text" />
                <Label fx:id="correoLabel" text="Correo:" styleClass="normal-text" />
                <Label fx:id="tipoLabel" text="Rol:" styleClass="normal-text" />

                <Button maxWidth="240.0" onAction="#onVolverClick" styleClass="primary-button" text="Volver al inicio" />
                <Button maxWidth="240.0" onAction="#onCerrarSesionClick" styleClass="danger-button" text="Cerrar sesión" />
            </children>
        </VBox>
    </children>
</AnchorPane>

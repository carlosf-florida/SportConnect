<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" styleClass="screen"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.sportconnect_01.controller.ProductosController">
    <children>
        <VBox layoutX="170.0" layoutY="45.0" prefHeight="510.0" prefWidth="560.0" spacing="14.0" styleClass="card">
            <children>
                <Label text="Productos" styleClass="title" />
                <Label text="Productos publicados por profesores o administradores." wrapText="true" maxWidth="500.0" styleClass="normal-text" />

                <ScrollPane fitToWidth="true" prefHeight="350.0" prefWidth="500.0" styleClass="transparent-scroll">
                    <content>
                        <VBox fx:id="listaProductosBox" spacing="12.0" />
                    </content>
                </ScrollPane>

                <Button maxWidth="220.0" onAction="#onVolverClick" styleClass="secondary-button" text="Volver al inicio" />
            </children>
        </VBox>
    </children>
</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" styleClass="screen"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.sportconnect_01.controller.HomeController">
    <children>
        <VBox alignment="CENTER" layoutX="225.0" layoutY="25.0" prefHeight="550.0" prefWidth="450.0" spacing="10.0" styleClass="card">
            <children>
                <Label fx:id="appNameLabel" text="⚽ SportConnect" styleClass="title" />
                <Label fx:id="bienvenidaLabel" text="Bienvenido" styleClass="subtitle" />
                <Label fx:id="tipoUsuarioLabel" text="Rol de usuario" styleClass="normal-text" />
                <Label fx:id="mensajeInicioLabel" text="Selecciona una opción" wrapText="true" maxWidth="350.0" styleClass="muted-text" />
                <Label fx:id="resumenLabel" text="Resumen" wrapText="true" maxWidth="350.0" styleClass="normal-text" />

                <Button maxWidth="285.0" onAction="#onVerClasesClick" styleClass="primary-button" text="Ver clases disponibles" />
                <Button maxWidth="285.0" onAction="#onMisClasesClick" styleClass="primary-button" text="Mis clases apuntadas" />
                <Button maxWidth="285.0" onAction="#onVerProfesoresClick" styleClass="primary-button" text="Ver profesores" />
                <Button maxWidth="285.0" onAction="#onProductosClick" styleClass="primary-button" text="Ver productos" />
                <Button maxWidth="285.0" onAction="#onMiPerfilClick" styleClass="primary-button" text="Mi perfil" />
                <Button fx:id="profesorButton" maxWidth="285.0" onAction="#onProfesorPanelClick" styleClass="profesor-button" text="Panel profesor" />
                <Button fx:id="adminButton" maxWidth="285.0" onAction="#onAdminClick" styleClass="admin-button" text="Panel admin" />
                <Button maxWidth="285.0" onAction="#onCerrarSesionClick" styleClass="danger-button" text="Cerrar sesión" />

                <Label fx:id="footerLabel" text="Proyecto JavaFX 1º DAM" wrapText="true" maxWidth="350.0" styleClass="muted-text" />
            </children>
        </VBox>
    </children>
</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" styleClass="screen"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.sportconnect_01.controller.MisClasesController">
    <children>
        <VBox layoutX="170.0" layoutY="35.0" prefHeight="530.0" prefWidth="560.0" spacing="14.0" styleClass="card">
            <children>
                <Label text="Mis clases apuntadas" styleClass="title" />
                <Label text="Consulta tus reservas y toda la información de cada clase." wrapText="true" maxWidth="500.0" styleClass="normal-text" />
                <Label fx:id="resumenMisClasesLabel" text="Resumen de clases" styleClass="muted-text" />

                <ScrollPane fitToWidth="true" prefHeight="335.0" prefWidth="500.0" styleClass="transparent-scroll">
                    <content>
                        <VBox fx:id="listaMisClasesBox" spacing="12.0" />
                    </content>
                </ScrollPane>

                <Button maxWidth="220.0" onAction="#onVerMasClasesClick" styleClass="primary-button" text="Buscar más clases" />
                <Button maxWidth="220.0" onAction="#onVolverClick" styleClass="secondary-button" text="Volver al inicio" />
            </children>
        </VBox>
    </children>
</AnchorPane>

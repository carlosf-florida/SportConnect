<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" styleClass="screen"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.sportconnect_01.controller.RegisterController">
    <children>
        <VBox alignment="CENTER" layoutX="250.0" layoutY="25.0" prefHeight="550.0" prefWidth="400.0" spacing="10.0" styleClass="card">
            <children>
                <Label text="⚽ SportConnect" styleClass="title" />
                <Label text="Crear cuenta" styleClass="subtitle" />
                <Label text="Campos preparados para la tabla usuarios." styleClass="muted-text" />

                <TextField fx:id="nombreField" maxWidth="270.0" promptText="Nombre" />
                <TextField fx:id="apellidoField" maxWidth="270.0" promptText="Apellido" />
                <TextField fx:id="nickField" maxWidth="270.0" promptText="Nick / nombre de usuario" />
                <TextField fx:id="correoField" maxWidth="270.0" promptText="Email" />
                <PasswordField fx:id="passwordField" maxWidth="270.0" promptText="Contraseña" />
                <PasswordField fx:id="repetirPasswordField" maxWidth="270.0" promptText="Repetir contraseña" />
                <ComboBox fx:id="tipoCombo" maxWidth="270.0" promptText="Rol" />

                <Label fx:id="mensajeLabel" text="" styleClass="error-text" />

                <Button maxWidth="270.0" onAction="#onCrearCuentaClick" styleClass="primary-button" text="Crear cuenta" />
                <Button maxWidth="270.0" onAction="#onVolverLoginClick" styleClass="secondary-button" text="Volver al login" />
            </children>
        </VBox>
    </children>
</AnchorPane>

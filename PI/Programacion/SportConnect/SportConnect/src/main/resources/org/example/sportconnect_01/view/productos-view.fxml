<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="1080.0" prefWidth="1920.0" styleClass="screen"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.sportconnect_01.controller.ProductosController">
    <children>
        <Region layoutX="0" layoutY="0" prefHeight="4" prefWidth="1920"
                style="-fx-background-color: linear-gradient(to right, transparent, #00d4ff, #6366f1, transparent);"/>
        <Region layoutX="0" layoutY="4" prefHeight="1076" prefWidth="5"
                style="-fx-background-color: linear-gradient(to bottom, #00d4ff, transparent);"/>

        <HBox layoutX="34.0" layoutY="28.0" prefWidth="1852.0" prefHeight="1024.0" spacing="28.0">

            <!-- Sidebar FIJO -->
            <VBox prefWidth="300.0" prefHeight="1024.0" spacing="14.0" styleClass="fixed-sidebar">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <VBox HBox.hgrow="ALWAYS" spacing="3">
                        <Label text="SportConnect" styleClass="brand-title" style="-fx-font-size: 22px;"/>
                        <Label fx:id="sidebarUserLabel" text="" styleClass="sidebar-user" style="-fx-font-size: 13px;"/>
                    </VBox>
                    <Button onAction="#onMiPerfilClick" text="👤 Perfil"
                            prefWidth="90" prefHeight="36" styleClass="primary-button" style="-fx-font-size: 12px;"/>
                </HBox>
                <Button onAction="#onCerrarSesionClick" text="⏻  Cerrar sesión"
                        prefWidth="270" prefHeight="36" styleClass="danger-button" style="-fx-font-size: 13px;"/>
                <Region prefHeight="1" prefWidth="250" styleClass="soft-divider"/>
                <Label text="Navegación rápida" styleClass="mini-title"/>
                <Button onAction="#onVolverClick"     text="🏠  Inicio"      prefWidth="270" styleClass="nav-button" style="-fx-pref-height: 38; -fx-font-size: 13px;"/>
                <Button onAction="#onClasesClick"     text="🏃  Clases"      prefWidth="270" styleClass="nav-button" style="-fx-pref-height: 38; -fx-font-size: 13px;"/>
                <Button onAction="#onMisClasesClick"  text="📋  Mis clases"  prefWidth="270" styleClass="nav-button" style="-fx-pref-height: 38; -fx-font-size: 13px;"/>
                <Button onAction="#onVerCarritoClick" text="🛒  Carrito"     prefWidth="270" styleClass="nav-button" style="-fx-pref-height: 38; -fx-font-size: 13px;"/>
            </VBox>

            <!-- Contenido principal -->
            <VBox prefWidth="1494.0" prefHeight="1024.0" spacing="18.0" styleClass="wide-card">

                <!-- Header -->
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <VBox spacing="6">
                        <Label text="Tienda" styleClass="title" style="-fx-font-size: 40px;"/>
                        <Label fx:id="carritoInfoLabel" text="0 artículos en el carrito" styleClass="muted-text" style="-fx-font-size: 16px;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button onAction="#onVerCarritoClick" styleClass="primary-button"
                            text="🛒  Ver carrito" style="-fx-pref-height: 44; -fx-font-size: 15px; -fx-min-width: 160;"/>
                </HBox>

                <!-- Filters -->
                <HBox spacing="14.0" alignment="CENTER_LEFT"
                      style="-fx-background-color: #0e1928; -fx-background-radius: 12; -fx-padding: 16 20;">
                    <TextField fx:id="busquedaField" promptText="Buscar productos..."
                               prefWidth="500.0" styleClass="text-field"
                               onKeyReleased="#onBuscarKeyReleased"
                               style="-fx-pref-height: 44; -fx-font-size: 15px;"/>
                    <ComboBox fx:id="filtroCombo" promptText="Tipo de producto" styleClass="combo-box"
                              prefWidth="260" style="-fx-pref-height: 44;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button onAction="#onBuscarClick" styleClass="primary-button" text="Buscar"
                            style="-fx-pref-height: 44; -fx-min-width: 120; -fx-font-size: 15px;"/>
                </HBox>

                <!-- Product grid -->
                <ScrollPane fitToWidth="true" prefHeight="860.0" styleClass="transparent-scroll">
                    <content>
                        <VBox fx:id="listaProductosBox" spacing="16.0"/>
                    </content>
                </ScrollPane>
            </VBox>
        </HBox>
    </children>
</AnchorPane>

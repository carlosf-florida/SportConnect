<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="1080.0" prefWidth="1920.0" styleClass="screen"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.sportconnect_01.controller.LoginController">
    <children>
        <!-- Accent bar top -->
        <Region layoutX="0" layoutY="0" prefHeight="4" prefWidth="1920"
                style="-fx-background-color: linear-gradient(to right, transparent, #00d4ff, #6366f1, transparent);"/>

        <!-- Left decorative panel -->
        <VBox alignment="CENTER" layoutX="0" layoutY="0" prefWidth="960" prefHeight="1080"
              style="-fx-background-color: linear-gradient(to bottom right, #060b12, #0e1928);">
            <Label text="◈ SportConnect"
                   style="-fx-font-size: 64px; -fx-font-weight: bold; -fx-text-fill: #00d4ff;
                          -fx-effect: dropshadow(gaussian, rgba(0,212,255,0.60), 40, 0.0, 0, 0);"/>
            <Region prefHeight="16"/>
            <Label text="Tu plataforma deportiva premium"
                   style="-fx-font-size: 22px; -fx-text-fill: #4a6080; -fx-letter-spacing: 2;"/>
            <Region prefHeight="48"/>
            <!-- Decorative icons row -->
            <HBox alignment="CENTER" spacing="48"
                  style="-fx-opacity: 0.90;">
                <Label text="🏋️" style="-fx-font-size: 52px; -fx-text-fill: #f0f6ff;"/>
                <Label text="🧘" style="-fx-font-size: 52px; -fx-text-fill: #f0f6ff;"/>
                <Label text="⚽" style="-fx-font-size: 52px; -fx-text-fill: #f0f6ff;"/>
                <Label text="🏊" style="-fx-font-size: 52px; -fx-text-fill: #f0f6ff;"/>
            </HBox>
        </VBox>

        <!-- Vertical divider -->
        <Region layoutX="959" layoutY="0" prefWidth="2" prefHeight="1080"
                style="-fx-background-color: linear-gradient(to bottom, transparent, rgba(0,212,255,0.30), transparent);"/>

        <!-- Right: login card -->
        <VBox alignment="CENTER" layoutX="960" layoutY="0" prefWidth="960" prefHeight="1080"
              style="-fx-background-color: #080d14;">
            <VBox alignment="CENTER" spacing="0" styleClass="card"
                  style="-fx-max-width: 480px; -fx-pref-width: 480px;">

                <Label text="Bienvenido de nuevo"
                       style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #f0f6ff;"/>
                <Region prefHeight="6"/>
                <Label text="Inicia sesión para continuar"
                       style="-fx-font-size: 15px; -fx-text-fill: #4a6080;"/>
                <Region prefHeight="32"/>
                <Region prefHeight="1" prefWidth="400"
                        style="-fx-background-color: rgba(0,212,255,0.15);"/>
                <Region prefHeight="28"/>

                <Label text="Correo electrónico" styleClass="muted-text"
                       style="-fx-padding: 0 0 6 2; -fx-alignment: CENTER_LEFT;" maxWidth="400"/>
                <TextField fx:id="correoField" maxWidth="400.0" promptText="usuario@email.com"
                           styleClass="text-field" style="-fx-pref-height: 48; -fx-font-size: 16px;"/>

                <Region prefHeight="18"/>

                <Label text="Contraseña" styleClass="muted-text"
                       style="-fx-padding: 0 0 6 2; -fx-alignment: CENTER_LEFT;" maxWidth="400"/>
                <PasswordField fx:id="passwordField" maxWidth="400.0" promptText="••••••••"
                               styleClass="password-field" style="-fx-pref-height: 48; -fx-font-size: 16px;"/>

                <Region prefHeight="10"/>
                <Label fx:id="mensajeLabel" text="" styleClass="error-text" maxWidth="400" wrapText="true"/>
                <Label fx:id="modoConexionLabel" text="" styleClass="muted-text" maxWidth="400" wrapText="true" alignment="CENTER"/>
                <Region prefHeight="22"/>

                <Button maxWidth="400.0" onAction="#onEntrarClick" styleClass="primary-button"
                        text="Entrar" prefWidth="400"
                        style="-fx-pref-height: 50; -fx-font-size: 16px;"/>
                <Region prefHeight="12"/>
                <Button maxWidth="400.0" onAction="#onRegistrarseClick" styleClass="secondary-button"
                        text="Crear cuenta" prefWidth="400"
                        style="-fx-pref-height: 50; -fx-font-size: 16px;"/>
                <Region prefHeight="16"/>
                <Button onAction="#onAyudaClick" styleClass="link-button"
                        text="Cuentas de prueba" style="-fx-font-size: 14px;"/>
            </VBox>
        </VBox>
    </children>
</AnchorPane>
